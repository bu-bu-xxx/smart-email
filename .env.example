# Smart Email 环境变量配置
# 复制此文件到 ~/.openclaw/.env 并填写实际值

# ============================================
# 邮箱配置（使用授权码，不是登录密码）
# ============================================

# QQ 邮箱
# 获取方式：QQ邮箱设置 → 账号 → 开启IMAP/SMTP服务 → 获取授权码
SMART_EMAIL_QQ_EMAIL=your_qq@qq.com
SMART_EMAIL_QQ_AUTH_CODE=your_16_digit_auth_code

# 126 邮箱
# 获取方式：邮箱设置 → POP3/SMTP/IMAP → 开启IMAP → 客户端授权密码
SMART_EMAIL_126_EMAIL=your_email@126.com
SMART_EMAIL_126_AUTH_CODE=your_auth_code

# 163 邮箱
# 获取方式：同上
SMART_EMAIL_163_EMAIL=your_email@163.com
SMART_EMAIL_163_AUTH_CODE=your_auth_code

# Outlook
# 获取方式：Microsoft账户 → 安全 → 双重验证 → 应用密码
SMART_EMAIL_OUTLOOK_EMAIL=your_email@outlook.com
SMART_EMAIL_OUTLOOK_APP_PASSWORD=your_app_password

# ============================================
# AI 配置（用于判断紧急邮件和生成摘要）
# ============================================

# 选择 AI 分析方式（必填）：openai | anthropic | subagent
SMART_EMAIL_LLM_PROVIDER=openai

# OpenAI 兼容 API 配置（当 LLM_PROVIDER=openai 时使用）
SMART_EMAIL_OPENAI_API_URL=https://api.example.com/v1
SMART_EMAIL_OPENAI_API_KEY=your_api_key
SMART_EMAIL_OPENAI_MODEL=gpt-4o-mini

# Anthropic API 配置（当 LLM_PROVIDER=anthropic 时使用）
SMART_EMAIL_ANTHROPIC_API_URL=https://api.minimaxi.com/anthropic
SMART_EMAIL_ANTHROPIC_API_KEY=your_api_key
SMART_EMAIL_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Subagent 并发配置（当 LLM_PROVIDER=subagent 时使用）
SMART_EMAIL_SUBAGENT_CONCURRENCY=5

# AI 并发请求限制（可选，默认 5）
# 用于限制同时调用 API 的请求数量，避免触发并发限制
SMART_EMAIL_MAX_CONCURRENT=5

# AI 分析限制（可选，默认 20）
# 每次 check 命令最多分析的邮件数量，防止超时
# 超过此数量的邮件会保留在本地，下次再分析
SMART_EMAIL_ANALYZE_LIMIT=20

# LLM 重试次数（可选，默认 3）
SMART_EMAIL_LLM_RETRY_COUNT=3

# LLM 重试间隔基数秒（可选，默认 1，指数退避）
SMART_EMAIL_LLM_RETRY_BASE_DELAY=1

# 多模态分析开关（可选，默认 false）
# 开启后，AI 分析时会输入邮件正文图片（如果存在图片，附件不作为输入）
# 注意：开启后会消耗更多 API 额度，且分析速度会变慢
SMART_EMAIL_MULTIMODAL_ANALYSIS=false

# 下载限制（可选，默认 50）
# 每次从邮箱下载的邮件数量上限
SMART_EMAIL_DOWNLOAD_LIMIT=50

# 检查间隔（可选，默认 30）
# cron 定时任务检查邮件的间隔（分钟）
SMART_EMAIL_CHECK_INTERVAL=30

# 每日汇总时间（可选，默认 11:00,17:00）
# 逗号分隔的24小时制时间，支持多个时间点
SMART_EMAIL_DIGEST_TIMES=11:00,17:00

# ============================================
# 发送渠道配置（必填）
# ============================================

# 发送渠道类型
# 可选值：telegram | dingtalk | wecom | discord
SMART_EMAIL_DELIVERY_CHANNEL=telegram

# 发送目标
# Telegram: @username 或 chat_id（如 -1001234567890）
# 钉钉: 群机器人的 webhook 关键字或用户ID
# 企业微信: 用户ID或群ID
SMART_EMAIL_DELIVERY_TARGET=@your_username


